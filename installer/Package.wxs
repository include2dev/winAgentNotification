<?xml version="1.0" encoding="UTF-8"?>
<!--
  MSI package definition for WinAgentNotification.

  Build (after `dotnet publish ... -o publish`):
    wix build installer/Package.wxs -arch x64 -ext WixToolset.Util.wixext \
      -d ProductVersion=1.0.0 -d PublishDir=publish -o WinAgentNotification-1.0.0.msi

  Variables:
    ProductVersion  numeric x.y.z (MSI requirement; derive from the git tag)
    PublishDir      folder produced by dotnet publish (harvested wholesale)

  IMPORTANT: UpgradeCode is a permanent identity — never change it, or
  upgrades stop replacing older installs and machines end up with two copies.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="WinAgentNotification"
           Manufacturer="include2dev"
           Version="$(var.ProductVersion)"
           UpgradeCode="80304831-B6AF-4C98-A83D-F8C98D4F5F83"
           Scope="perMachine"
           Compressed="yes">

    <!-- A newer version replaces the old one; block downgrades. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of WinAgentNotification is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Stop a running agent before upgrade or uninstall. -->
    <util:CloseApplication Id="CloseAgent"
                           Target="WinAgentNotification.exe"
                           CloseMessage="yes"
                           RebootPrompt="no"
                           TerminateProcess="1" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="WinAgentNotification">
        <!-- Harvest the entire publish output (exe, runtime, appsettings.json).
             Note: upgrades overwrite appsettings.json by design — IT owns the
             config centrally. Revisit if per-machine edits must survive. -->
        <Files Include="$(var.PublishDir)\**" />
      </Directory>
    </StandardDirectory>

    <!-- Start after login for every user of the machine. -->
    <Component Id="AutoStartRunKey" Directory="INSTALLFOLDER">
      <RegistryValue Root="HKLM"
                     Key="Software\Microsoft\Windows\CurrentVersion\Run"
                     Name="WinAgentNotification"
                     Value="&quot;[INSTALLFOLDER]WinAgentNotification.exe&quot;"
                     Type="string"
                     KeyPath="yes" />
    </Component>

    <!-- Launch immediately after an interactive install (fresh install and
         major upgrade both run with Installed unset). When deployed silently
         under SYSTEM (Intune/GPO) there is no user desktop; the Run key
         covers the next logon instead. -->
    <SetProperty Id="WixShellExecTarget"
                 Value="[INSTALLFOLDER]WinAgentNotification.exe"
                 After="CostFinalize" />
    <CustomAction Id="LaunchAgent"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
                  DllEntry="WixShellExec"
                  Impersonate="yes" />
    <InstallExecuteSequence>
      <Custom Action="LaunchAgent" After="InstallFinalize"
              Condition="NOT Installed AND NOT REMOVE" />
    </InstallExecuteSequence>

  </Package>
</Wix>
