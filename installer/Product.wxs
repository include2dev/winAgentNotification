<?xml version="1.0" encoding="UTF-8"?>
<!--
  MSI package definition for WinAgentNotification, authored for msitools'
  `wixl` (WiX v3 syntax subset) so the MSI builds natively on Linux CI.
  Note: WiX v4+ itself cannot build MSIs on non-Windows (Directory/@Name
  validation fails; the toolset declares non-Windows behavior undefined),
  which is why this project uses wixl.

  Build (see build/build-msi.sh for the full pipeline):
    1. dotnet publish src/WinAgentNotification.App -c Release -r win-x64 \
         - -self-contained true -o publish
    2. (cd publish && find . -type f) | wixl-heat -p ./ \
         - -component-group CG.App - -directory-ref INSTALLFOLDER \
         - -var var.PublishDir - -win64 > harvest.wxs
    3. wixl -a x64 -D ProductVersion=1.0.0 -D PublishDir=publish \
         installer/Product.wxs harvest.wxs -o WinAgentNotification-1.0.0.msi
  (dashes in the comment above are split to keep XML comments valid;
   the real commands live in build/build-msi.sh)

  Variables:
    ProductVersion  numeric x.y.z (MSI requirement; derive from the git tag)
    PublishDir      folder produced by dotnet publish

  IMPORTANT: UpgradeCode is a permanent identity - never change it, or
  upgrades stop replacing older installs and machines end up with two copies.

  Known POC limitation: no close-running-app custom action (wixl has no
  WiX util extension). Upgrading while the agent is running may require
  a logoff/logon for the new version to take over.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="WinAgentNotification"
           Manufacturer="include2dev"
           Version="$(var.ProductVersion)"
           Language="1033"
           UpgradeCode="80304831-B6AF-4C98-A83D-F8C98D4F5F83">

    <Package Description="NATS desktop notification agent"
             InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine" />

    <Media Id="1" Cabinet="app.cab" EmbedCab="yes" />

    <!-- A newer version replaces the old one; block downgrades. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of WinAgentNotification is already installed." />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="WinAgentNotification" />
      </Directory>
    </Directory>

    <!-- Start after login for every user of the machine. -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="AutoStartRunKey" Guid="6E1D9E4F-3A20-4B0C-9E8A-2F5D1C7B9A31" Win64="yes">
        <RegistryValue Root="HKLM"
                       Key="Software\Microsoft\Windows\CurrentVersion\Run"
                       Name="WinAgentNotification"
                       Value="&quot;[INSTALLFOLDER]WinAgentNotification.exe&quot;"
                       Type="string"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <Feature Id="Main" Title="WinAgentNotification" Level="1">
      <!-- CG.App is generated by wixl-heat from the publish folder. -->
      <ComponentGroupRef Id="CG.App" />
      <ComponentRef Id="AutoStartRunKey" />
    </Feature>

  </Product>
</Wix>
